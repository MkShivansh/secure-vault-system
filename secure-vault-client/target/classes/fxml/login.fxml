<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" spacing="20" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.securevaultclient.controller.LoginController">
    <padding>
        <Insets bottom="30" left="30" right="30" top="30" />
    </padding>
    
    <Label text="Secure Digital Vault" textFill="#2c3e50">
        <font>
            <Font name="System Bold" size="24" />
        </font>
    </Label>
    
    <Label text="Login" textFill="#34495e">
        <font>
            <Font size="18" />
        </font>
    </Label>
    
    <TextField fx:id="usernameField" promptText="Enter username" maxWidth="250" />
    
    <Button fx:id="loginButton" defaultButton="true" maxWidth="250" mnemonicParsing="false" onAction="#handleLogin" style="-fx-background-color: #3498db; -fx-text-fill: white;" text="Login">
        <font>
            <Font size="14" />
        </font>
    </Button>
</VBox>