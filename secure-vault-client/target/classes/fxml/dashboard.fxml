<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" 
            fx:controller="com.securevaultclient.controller.DashboardController">
    
    <top>
        <VBox alignment="CENTER" spacing="10" style="-fx-background-color: #2c3e50;">
            <padding>
                <Insets bottom="15" left="15" right="15" top="15" />
            </padding>
            
            <Label fx:id="welcomeLabel" text="Welcome!" textFill="white">
                <font>
                    <Font name="System Bold" size="20" />
                </font>
            </Label>
        </VBox>
    </top>
    
    <center>
        <GridPane alignment="CENTER" hgap="20" vgap="20">
            <padding>
                <Insets bottom="30" left="30" right="30" top="30" />
            </padding>
            
            <!-- Row 0 -->
            <Button fx:id="addFileBtn" mnemonicParsing="false" onAction="#handleAddFile" 
                    prefHeight="100" prefWidth="150" 
                    style="-fx-background-color: #27ae60; -fx-text-fill: white;" 
                    text="Add File" GridPane.rowIndex="0" GridPane.columnIndex="0">
                <font><Font size="14" /></font>
            </Button>
            
            <Button fx:id="viewFilesBtn" mnemonicParsing="false" onAction="#handleViewFiles" 
                    prefHeight="100" prefWidth="150" 
                    style="-fx-background-color: #2980b9; -fx-text-fill: white;" 
                    text="View Files" GridPane.rowIndex="0" GridPane.columnIndex="1">
                <font><Font size="14" /></font>
            </Button>
            
            <!-- Row 1 -->
            <Button fx:id="verifyBtn" mnemonicParsing="false" onAction="#handleVerifyFile" 
                    prefHeight="100" prefWidth="150" 
                    style="-fx-background-color: #f39c12; -fx-text-fill: white;" 
                    text="Verify File" GridPane.rowIndex="1" GridPane.columnIndex="0">
                <font><Font size="14" /></font>
            </Button>
            
            <Button fx:id="auditBtn" mnemonicParsing="false" onAction="#handleViewAudit" 
                    prefHeight="100" prefWidth="150" 
                    style="-fx-background-color: #8e44ad; -fx-text-fill: white;" 
                    text="View Audit" GridPane.rowIndex="1" GridPane.columnIndex="1">
                <font><Font size="14" /></font>
            </Button>
            
            <!-- Row 2 -->
            <Button fx:id="servletBtn" mnemonicParsing="false" onAction="#handleServlet" 
                    prefHeight="100" prefWidth="150" 
                    style="-fx-background-color: #16a085; -fx-text-fill: white;" 
                    text="Call Servlet" GridPane.rowIndex="2" GridPane.columnIndex="0">
                <font><Font size="14" /></font>
            </Button>
            
            <!-- Row 3 -->
            <Button fx:id="logoutBtn" mnemonicParsing="false" onAction="#handleLogout" 
                    prefHeight="50" prefWidth="320" 
                    style="-fx-background-color: #e74c3c; -fx-text-fill: white;" 
                    text="Logout" GridPane.columnSpan="2" GridPane.rowIndex="3">
                <font><Font size="14" /></font>
            </Button>
        </GridPane>
    </center>
</BorderPane>